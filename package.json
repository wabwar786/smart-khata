{
  "name": "smart-khata-api",
  "version": "1.0.1",
  "private": true,
  "description": "Smart Khata Accounting SaaS backend API for Android app and web admin panel",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node scripts/migrate.js",
    "migrate": "node scripts/migrate.js",
    "create:admin": "node scripts/create-super-admin.js",
    "db:seed:demo": "node scripts/seed-mobile-shop-demo.js",
    "db:setup": "node scripts/setup-db.js",
    "db:setup:demo": "npm run db:migrate && npm run db:seed:demo",
    "start:railway": "npm run db:setup:demo && node server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
