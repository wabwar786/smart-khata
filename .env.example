# Railway PostgreSQL connection string
DATABASE_URL=

# API settings
NODE_ENV=development
PORT=8080
JWT_SECRET=change-this-to-a-long-random-secret-before-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# Optional script values for npm run create:admin
SUPER_ADMIN_NAME=Smart Khata Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PHONE=
SUPER_ADMIN_PASSWORD=ChangeMe123!

# WhatsApp OTP engine. Keep the API key on backend only, never inside APK.
WA_ENGINE_BASE_URL=https://wa-engine-deploy-production.up.railway.app
WA_ENGINE_API_KEY=
# Set true only for testing if you want OTP returned in API response when WhatsApp is not configured.
ALLOW_DEMO_OTP=false
